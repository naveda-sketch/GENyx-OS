#!/bin/bash
#
# CANDADO FE-#7 — Doctrina-First Verification (commit-msg hook)
# Repo: swift-viking (frontend)
#
# Origen: regla de oro fundador 22-may-2026 — "siempre mirar nuestra
# doctrina antes de actuar".
#
# Filosofía: 1000 candados > 1000 reglas. Convierte la expectativa
# implícita ("consulta doctrina") en validación técnica ("commit debe
# citar regla/pattern aplicado").
#
# ── Cómo funciona ─────────────────────────────────────────────────
# Escanea el commit message buscando AL MENOS UN match a:
#   - "REGLA N" (referencia a regla doctrinal numerada)
#   - "METODOLOGÍA" / "metodologia" / "Pattern:" (razonamiento metodológico)
#   - "doctrina" (referencia explícita)
#   - "candado #N" / "Candado #N" (referencia a candado activo)
#   - "AUDIT" / "auditoría" en contexto técnico
#
# Si NO encuentra ninguna referencia → bloquea commit con mensaje claro.
#
# Bypass consciente: GENYX_NO_DOCTRINA=1 git commit ...
# (debe documentarse la razón en el siguiente commit)
# ────────────────────────────────────────────────────────────────────

set -e

# Bypass consciente
if [ "$GENYX_NO_DOCTRINA" = "1" ]; then
    echo "✓ GENYX_NO_DOCTRINA=1 — bypass doctrinal (debe documentar razón)"
    exit 0
fi

COMMIT_MSG_FILE="$1"
if [ -z "$COMMIT_MSG_FILE" ] || [ ! -f "$COMMIT_MSG_FILE" ]; then
    exit 0
fi

MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits, revert commits, fixup/squash (autogenerated)
if echo "$MSG" | head -1 | grep -qiE "^(Merge|Revert|fixup!|squash!)"; then
    exit 0
fi

# Skip muy cortos (probablemente WIP / amend / experiments locales)
LINES_COUNT=$(echo "$MSG" | grep -v "^#" | grep -v "^$" | wc -l | tr -d ' ')
if [ "$LINES_COUNT" -lt 3 ]; then
    exit 0
fi

# Pattern doctrinal: al menos UNA de estas referencias
DOCTRINAL_PATTERNS=(
    "REGLA\s*[0-9]+"
    "[Mm]etodolog[ií]a"
    "Pattern:"
    "Pattern Name"
    "doctrina"
    "[Cc]andado\s*#?[0-9]"
    "AUDIT"
    "auditoría"
    "TRAZABILIDAD"
    "trazabilidad"
)

FOUND=0
for pattern in "${DOCTRINAL_PATTERNS[@]}"; do
    if echo "$MSG" | grep -qE "$pattern"; then
        FOUND=1
        break
    fi
done

if [ "$FOUND" -eq 1 ]; then
    echo "✓ CANDADO FE-#7: commit cita doctrina/pattern/candado"
    exit 0
fi

# NO hay referencia doctrinal → bloquear
cat <<'BLOCK'

🚨 ═══════════════════════════════════════════════════════════════
🚨  CANDADO FE-#7 BLOQUEÓ — Doctrina-First Verification
🚨 ═══════════════════════════════════════════════════════════════

Tu commit message NO contiene referencia explícita a doctrina:
  · REGLA N           (ej: "REGLA 14")
  · METODOLOGÍA       (ej: "METODOLOGÍA: Source of Truth Priority")
  · Pattern: ...      (ej: "Pattern: Bootstrap")
  · doctrina
  · candado #N        (ej: "candado #4")
  · AUDIT / auditoría
  · trazabilidad / TRAZABILIDAD

─── Cómo arreglar ───────────────────────────────────────────────

Agrega al commit message una sección que cite la doctrina aplicada:

  METODOLOGÍA (REGLA 14): Silent Failure Elimination — cada fetch
  debe manejar timeout, non-200 y network error.

─── Bypass consciente ───────────────────────────────────────────

GENYX_NO_DOCTRINA=1 git commit ...

(documenta la razón en el SIGUIENTE commit normal)

═══════════════════════════════════════════════════════════════════

BLOCK

exit 1
