#!/bin/bash
#
# CANDADO FE-#3 — Check-Agnostic REGLA 11 (pre-commit hook)
# Repo: swift-viking (frontend)
#
# Origen: decreto fundador — GenyX es 100% agnóstico por industria,
# canal, LLM y tamaño de negocio.
#
# Filosofía: 1000 candados > 1000 reglas. Esta verificación previene
# que palabras prohibidas entren al codebase vía commit.
#
# ── Cómo funciona ─────────────────────────────────────────────────
# Escanea archivos staged (JSX/TSX/JS/TS/CSS/HTML) buscando patterns
# prohibidos por REGLA 11:
#   - PyME / pyme / PYME
#   - SMB / small business
#   - starter / growth / autonomy (planes viejos)
#   - Director General (renombrado a Arquitecto en A0)
#   - "sin GenyX" / "reemplaza humanos/empleados/personal"
#
# Excepciones: archivos en CEREBRO_GENYX/, *.md (docs), commit messages.
# Si un match es false positive → bypass con GENYX_AGNOSTIC_OVERRIDE=1
#
# Bypass consciente: GENYX_AGNOSTIC_OVERRIDE=1 git commit ...
# (debe documentarse la razón en el commit message)
# ────────────────────────────────────────────────────────────────────

set -e

# Bypass consciente
if [ "$GENYX_AGNOSTIC_OVERRIDE" = "1" ]; then
    echo "✓ GENYX_AGNOSTIC_OVERRIDE=1 — bypass REGLA 11 (debe documentar razón)"
    exit 0
fi

# Patterns prohibidos REGLA 11
PROHIBITED_PATTERNS=(
    '\bPyMEs?\b'
    '\bpymes?\b'
    '\bSMB\b'
    '\bsmall business\b'
    '\bempresa[s]?\s+(chica|pequeña)[s]?\b'
    '\bSTARTER\b'
    '\bGROWTH\b'
    '\bAUTONOMY\b'
    '\b[Ss]tarter\b'
    '\b[Gg]rowth\b'
    '\b[Aa]utonomy\b'
    '\bDirector General\b'
    '\bsin GenyX\b'
    '\breemplaza\s+(humanos|empleados|personal)\b'
)

# Solo escanear archivos staged que son código frontend
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | \
    grep -E '\.(jsx?|tsx?|css|html)$' | \
    grep -v 'CEREBRO_GENYX/' | \
    grep -v 'node_modules/' | \
    grep -v '\.min\.' || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

VIOLATIONS=0
VIOLATION_DETAILS=""

for file in $STAGED_FILES; do
    if [ ! -f "$file" ]; then
        continue
    fi
    for pattern in "${PROHIBITED_PATTERNS[@]}"; do
        MATCHES=$(grep -nE "$pattern" "$file" 2>/dev/null || true)
        if [ -n "$MATCHES" ]; then
            # Check if it's in a comment (// or /* or * line)
            REAL_MATCHES=$(echo "$MATCHES" | grep -vE '^\s*//|^\s*\*|^\s*/\*' || true)
            if [ -n "$REAL_MATCHES" ]; then
                VIOLATIONS=$((VIOLATIONS + 1))
                VIOLATION_DETAILS="${VIOLATION_DETAILS}\n  📍 ${file}:\n$(echo "$REAL_MATCHES" | head -3 | sed 's/^/      /')\n"
            fi
        fi
    done
done

if [ "$VIOLATIONS" -eq 0 ]; then
    echo "✓ CANDADO FE-#3: REGLA 11 — 0 violaciones agnósticas en staged files"
    exit 0
fi

cat <<BLOCK

🚨 ═══════════════════════════════════════════════════════════════
🚨  CANDADO FE-#3 BLOQUEÓ — REGLA 11 Violación Agnóstica
🚨 ═══════════════════════════════════════════════════════════════

Se encontraron ${VIOLATIONS} violación(es) de REGLA 11 en archivos staged:

$(echo -e "$VIOLATION_DETAILS")

─── Palabras prohibidas (REGLA 11) ──────────────────────────────

  PyME/pyme · SMB · small business · empresa chica/pequeña
  starter · growth · autonomy (planes viejos)
  Director General · sin GenyX · reemplaza humanos/empleados

─── Cómo arreglar ───────────────────────────────────────────────

Reemplaza por lenguaje agnóstico:
  PyME → negocio / comercio / tenant
  SMB → negocio independiente
  starter → esencial
  growth → profesional
  autonomy → enterprise
  Director General → Arquitecto (A0) o Dirección Ejecutiva (A11)

─── Bypass consciente ───────────────────────────────────────────

GENYX_AGNOSTIC_OVERRIDE=1 git commit ...

(documenta la razón en el commit message)

═══════════════════════════════════════════════════════════════════

BLOCK

exit 1
